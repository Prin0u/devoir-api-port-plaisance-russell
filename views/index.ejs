<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/index.css" />
    <title>Port de plaisance Russell</title>
  </head>
  <body>
    <div class="contenu-principal">
        <%- include('partials/navbar') %>
      <main>
        <section class="intro">
          <h2>
            Bienvenue sur mon application de gestion du port de plaisance
            Russell.
          </h2>
          <p>
            Cette application vous permet de gérer les catways, les réservations
            et les utilisateurs du port de plaisance Russell.
          </p>
        </section>

        <section class="login">
          <h2>Connexion</h2>
          <% if (messages.error && messages.error.length > 0) { %>
            <p style="color: red;"><%= messages.error[0] %></p>
          <% } %>
          <form action="/users/login" method="POST">
            <div class="form-login">
              <label for="email">Email :</label>
              <input type="email" id="email" name="email" required /><br />
            </div>
            <div class="form-login">
              <label for="password">Mot de passe :</label>
              <input
                type="password"
                id="password"
                name="password"
                required
              /><br />
            </div>
            <div class="connect-button">
              <button type="submit">Se connecter</button>
            </div>
          </form>
        </section>

        <section></section>
      </main>
    </div>
    <%- include('partials/footer') %>
  </body>
</html>
