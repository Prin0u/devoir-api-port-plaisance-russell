<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/reservations.css">
    <title>Gestion des réservations</title>
</head>
<body>
    <header>
      <%- include('partials/navbar') %>
        <h1>Réservations</h1>
    </header>
    <main>
        <% if (messages && Object.keys(messages).length > 0) { %>
            <div id="flash-messages">
              <% Object.keys(messages).forEach(type => { %>
                <% messages[type].forEach(msg => { %>
                  <div class="flash <%= type %>"><%= msg %></div>
                <% }) %>
              <% }) %>
            </div>
          <% } %>        
          <section class="create-reservations">
            <h2>Créer une nouvelle Réservation</h2>
            <form action="/reservations" method="POST">
              <label for="catwayNumber">Numéro de Catway :</label>
              <input type="text" name="catwayNumber" id="catwayNumber" required />
    
              <label for="clientName">Nom du client :</label>
              <input type="text" name="clientName" id="clientName" required />
              
              <label for="boatName">Nom du bateau :</label>
              <input type="text" name="boatName" id="boatName" required />
    
              <label for="startDate">Date de début :</label>
              <input type="date" name="startDate" id="startDate" required />
    
              <label for="endDate">Date de fin :</label>
              <input type="date" name="endDate" id="endDate" required />
    
              <button type="submit" class="btn-create">Créer</button>
            </form>
          </section>
          <h2>Liste des réservations</h2>
        <section class="reservations-list">
            
            <% if (reservations.length === 0) { %>
            <p>Aucune réservation trouvée</p>
            <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Catway</th>
                        <th>Client</th>
                        <th>Bateau</th>
                        <th>Début de réservation</th>
                        <th>Fin de réservation</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% reservations.forEach(res => { %>
                    <tr>
                        <td><%= res.catwayNumber %></td>
                        <td><%= res.clientName %></td>
                        <td><%= res.boatName %></td>
                        <td><%= res.startDate ? res.startDate.toISOString().slice(0, 10) : '' %></td>
                        <td><%= res.endDate ? res.endDate.toISOString().slice(0, 10) : '' %></td>
                        <td>
                            <a href="/reservations/<%= res._id %>/edit" class="btn-edit">Modifier</a>
                            <form action="/reservations/<%= res._id %>?_method=DELETE" method="POST">
                              <button type="submit" class="btn-danger" onclick="return confirm('Supprimer cette réservation ?') ">Supprimer</button>
                            </form>
                            
                          </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </section>

    </main>
    <%- include('partials/footer') %>
</body>
</html>